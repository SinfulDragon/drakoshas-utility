# --- Foundry VTT ---
# Path to your Foundry VTT Data folder.
# Windows example: C:\Users\YourName\AppData\Local\FoundryVTT\Data
# WSL2 example:    /home/yourname/foundrydata
# Leave empty to skip auto-linking the module.
FOUNDRY_DATA_PATH=