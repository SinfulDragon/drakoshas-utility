{
  "name": "Drakosha's Utility",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "remoteUser": "node",
  "workspaceFolder": "/workspaces/drakoshas-utility",
  "postCreateCommand": "git config --global --add safe.directory /workspaces/drakoshas-utility && bash .devcontainer/post-create.sh",

  "customizations": {
    "vscode": {
      "extensions": ["dbaeumer.vscode-eslint", "esbenp.prettier-vscode"],
      "settings": {
        "js/ts.tsdk.path": "node_modules/typescript/lib",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  }
}
